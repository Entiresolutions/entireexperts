# Copy to .env.local and fill in real values. Never commit .env.local.

# Canonical site URL used for metadata, sitemap, and OG tags.
SITE_URL=https://www.entirexperts.com
NEXT_PUBLIC_SITE_URL=https://www.entirexperts.com

# Resend (https://resend.com) — leave unset in development to log emails instead of sending them.
RESEND_API_KEY=

# Destination inbox for lead notifications, and the verified sending address for outbound mail.
CONTACT_TO_EMAIL=sales@entirexperts.com
CONTACT_FROM_EMAIL=no-reply@entirexperts.com

# Cloudflare Turnstile (https://developers.cloudflare.com/turnstile/) — leave unset to disable the widget.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# In-memory rate limiting for /api/contact, /api/quote, /api/leads, /api/chat.
RATE_LIMIT_MAX_REQUESTS=5
RATE_LIMIT_WINDOW_SECONDS=60

# Google Search Console domain verification (HTML tag method).
GOOGLE_SITE_VERIFICATION=

# Optional analytics — each is independently opt-in and no-ops when unset.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_CLARITY_PROJECT_ID=
